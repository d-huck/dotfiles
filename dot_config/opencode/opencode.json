{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen/qwen3-coder-30b": {
          "name": "Qwen3 Coder 30b (local)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  },
  "permission": {
    "read": "allow",
    "edit": "ask",
    "write": "ask",
    "webfetch": "allow",
    "websearch": "allow",
    "bash": {
      "*": "ask",
      "git commit *": "deny",
      "git push *": "deny",
      "git push": "deny"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 6000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".venv/**",
      "venv/**",
      "__pycache__/**",
      "*.pyc",
      ".git/**",
      "dist/**",
      "build/**",
      "*.egg-info/**",
      ".tox/**",
      ".mypy_cache/**",
      ".pytest_cache/**",
      "*.lock"
    ]
  },
  "autoupdate": true,
  "agent": {
    "general": {
      "model": "github-copilot/gpt-4.1",
      "permission": {
        "bash": {
          "*": "ask",
          "git commit *": "deny",
          "git push *": "deny",
          "git push": "deny"
        }
      }
    },
    "explore": {
      "model": "github-copilot/gpt-4.1",
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "allow",
          "git commit *": "deny",
          "git push *": "deny",
          "git push": "deny"
        }
      }
    },
    "summary": {
      "model": "github-copilot/gpt-5-mini"
    },
    "title": {
      "model": "github-copilot/gpt-5-mini"
    },
    "compaction": {
      "model": "github-copilot/gpt-5-mini"
    }
  }
}
