{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen/qwen3-coder-30b": {
          "name": "Qwen3 Coder 30b (local)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "qwen/qwen3.5-9b": {
          "name": "Qwen3.5 9b (local)",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        },
        "qwen3.5-27b-claude-opus-4.6-distill": {
          "name": "Qwen3.5 27b Claude Opus Distill (local)",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        },
        "mlmlml": {
          "name": "MLMLML (local)",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        },
        "qwen/qwen3-4b-thinking-2507": {
          "name": "Qwen3 4b Thinking (local)",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "kubernetes": {
      "type": "local",
      "command": ["npx", "-y", "kubernetes-mcp-server@latest", "--read-only"]
    },
    "terraform": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "hashicorp/terraform-mcp-server:0.4.0"]
    },
    "ansible": {
      "type": "local",
      "command": ["{{ .chezmoi.homeDir }}/.local/share/mcp-ansible/.venv/bin/python", "{{ .chezmoi.homeDir }}/.local/share/mcp-ansible/src/ansible_mcp/server.py"]
    }
  },
  "permission": {
    "read": "allow",
    "edit": "ask",
    "write": "ask",
    "webfetch": "allow",
    "websearch": "allow",
    "bash": {
      "*": "ask",
      "git commit *": "deny",
      "git push *": "deny",
      "git push": "deny",
      "sleep *": "allow",
      "terraform apply": "deny",
      "terraform apply *": "deny",
      "terraform destroy": "deny",
      "terraform destroy *": "deny",
      "terraform import *": "deny",
      "terraform taint *": "deny",
      "terraform untaint *": "deny",
      "terraform state mv *": "deny",
      "terraform state rm *": "deny",
      "terraform state push *": "deny"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 6000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".venv/**",
      "venv/**",
      "__pycache__/**",
      "*.pyc",
      ".git/**",
      "dist/**",
      "build/**",
      "*.egg-info/**",
      ".tox/**",
      ".mypy_cache/**",
      ".pytest_cache/**",
      "*.lock"
    ]
  },
  "autoupdate": true,
  "default_agent": "team-leader",
  "agent": {
    "general": {
{{- if .opencode.general }}
      "model": "{{ .opencode.general }}",
{{- end }}
      "permission": {
        "bash": {
          "*": "ask",
          "git commit *": "deny",
          "git push *": "deny",
          "git push": "deny",
          "terraform apply": "deny",
          "terraform apply *": "deny",
          "terraform destroy": "deny",
          "terraform destroy *": "deny",
          "terraform import *": "deny",
          "terraform taint *": "deny",
          "terraform untaint *": "deny",
          "terraform state mv *": "deny",
          "terraform state rm *": "deny",
          "terraform state push *": "deny"
        }
      }
    },
    "explore": {
{{- if .opencode.explore }}
      "model": "{{ .opencode.explore }}",
{{- end }}
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "allow",
          "git commit *": "deny",
          "git push *": "deny",
          "git push": "deny",
          "terraform apply": "deny",
          "terraform apply *": "deny",
          "terraform destroy": "deny",
          "terraform destroy *": "deny",
          "terraform import *": "deny",
          "terraform taint *": "deny",
          "terraform untaint *": "deny",
          "terraform state mv *": "deny",
          "terraform state rm *": "deny",
          "terraform state push *": "deny"
        }
      }
    },
    "codebase-qa": {
{{- if .opencode.codebase_qa }}
      "model": "{{ .opencode.codebase_qa }}",
{{- end }}
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": "deny"
      }
    }
{{- if or .opencode.summary .opencode.title .opencode.compaction }},
{{- if .opencode.summary }}
    "summary": {
      "model": "{{ .opencode.summary }}"
    }{{ if or .opencode.title .opencode.compaction }},{{ end }}
{{- end }}
{{- if .opencode.title }}
    "title": {
      "model": "{{ .opencode.title }}"
    }{{ if .opencode.compaction }},{{ end }}
{{- end }}
{{- if .opencode.compaction }}
    "compaction": {
      "model": "{{ .opencode.compaction }}"
    }
{{- end }}
{{- end }}
  }
}
